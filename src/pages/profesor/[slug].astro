---
import Layout from '../../layouts/Layout.astro';
import { lessons } from '../../lib/classes';
import { modules } from '../../lib/modules';

export function getStaticPaths() {
  return lessons.map((l) => ({ params: { slug: l.slug } }));
}

const { slug } = Astro.params;
const lesson = lessons.find((l) => l.slug === slug);
if (!lesson) return Astro.redirect('/plan');

const mod = modules.find((m) => m.id === lesson.moduleId);

const slides = [
  {
    k: 'cover',
    title: `Clase ${String(lesson.n).padStart(2, '0')} — ${lesson.title}`,
    body: `Modo profesor (2.5h). Módulo: ${mod?.title ?? ''}`,
    note: 'Abrí con contexto: qué van a poder hacer hoy y por qué importa. Recordá: sin frameworks obligatorios.',
    time: '5 min',
  },
  {
    k: 'outcome',
    title: 'Resultado esperado (promesa)',
    body: lesson.outcome,
    note: 'Decí la promesa en una frase. Pedí “ok” y seguí. Esto alinea energía.',
    time: '3 min',
  },
  {
    k: 'agenda',
    title: 'Agenda (2.5h)',
    bullets: [
      'Contexto + definiciones (rápido, sin humo)',
      'Demo / ejemplo (1 cosa que sorprende)',
      'Construcción guiada paso a paso',
      'Ejercicio individual + checklist',
      'Cierre: aprendizaje + tarea + siguiente clase',
    ],
    note: 'Mostrá el mapa. Avisá: “vamos a iterar, no a perfeccionar”.',
    time: '4 min',
  },
  {
    k: 'concepts',
    title: 'Conceptos clave (lo mínimo)',
    bullets: [
      'Definición 1: qué estamos haciendo y qué NO',
      'Regla 1: si no es usable, no cuenta',
      'Regla 2: una mejora visible por clase',
      'Regla 3: commit claro, siempre',
    ],
    note: 'Acá poné 2–4 definiciones. Si te vas por las ramas, se muere la clase.',
    time: '15 min',
  },
  {
    k: 'demo',
    title: 'Demo rápida (show, don’t tell)',
    body: 'Mostrá el “antes/después” o una web real que haga esto. 3 minutos, no más.',
    note: 'Elegí un ejemplo que impacte. “Esto es lo que van a poder hacer hoy”.',
    time: '10 min',
  },
  {
    k: 'build',
    title: 'Build guiado (script)',
    bullets: [
      'Paso 1 — Crear el archivo / sección',
      'Paso 2 — Estructura HTML',
      'Paso 3 — Estilos (jerarquía, spacing, contraste)',
      'Paso 4 — JS: interacción/estado (si aplica)',
      'Paso 5 — Probar en móvil + arreglar 1 fricción',
      'Paso 6 — Commit + push',
    ],
    note: 'Clave: hablá mientras codeás. Después de cada paso, preguntá: “¿todos igual?”',
    time: '75 min',
  },
  {
    k: 'exercise',
    title: 'Ejercicio (30–40 min)',
    bullets: [
      'Hacer 1 mejora visible y útil',
      'Agregar 1 micro-interacción',
      'Corregir 1 problema de claridad (copy/UX)',
      'Hacer 1 commit con mensaje claro',
    ],
    note: 'Mientras trabajan: hacé rondas y destrabá. Si alguien se tranca, bajá el scope.',
    time: '35 min',
  },
  {
    k: 'wrap',
    title: 'Cierre',
    bullets: [
      '1 aprendizaje (cada uno escribe 1 línea)',
      '1 duda abierta (para la próxima)',
      'Tarea para casa (10–20 min)',
    ],
    note: 'Cerrá con “qué sigue” y el link a la siguiente clase.',
    time: '10 min',
  },
];
---

<Layout title={`Profesor — ${lesson.title}`}>
  <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <div class="text-xs tracking-[0.22em] text-white/60">MODO PROFESOR</div>
        <h1 class="mt-2 text-2xl md:text-4xl font-extrabold tracking-tight">{lesson.title}</h1>
        <div class="mt-2 text-white/70">2.5 horas · 1 por semana · script + diapositivas interactivas</div>
      </div>
      <div class="flex gap-2">
        <a class="rounded-[2rem] border border-white/10 bg-white/5 px-4 py-3 font-semibold" href={`/clase/${lesson.slug}`}>Ver versión alumno</a>
        <a class="rounded-[2rem] bg-[color:var(--champagne)] px-4 py-3 font-semibold text-[#0D0D12]" href="/plan">Plan</a>
      </div>
    </div>

    <div class="mt-8 rounded-[2.5rem] border border-white/10 bg-white/5 p-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
          CONTROLES
        </div>
        <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
          ← / → · Space · Esc · T (timer)
        </div>
      </div>

      <div class="mt-4 grid gap-4 lg:grid-cols-[1fr,360px]">
        <div class="rounded-[2rem] border border-white/10 bg-[#0D0D12]/35 p-6">
          <div id="slideMeta" class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}></div>
          <div id="slideTitle" class="mt-2 text-2xl md:text-3xl font-extrabold tracking-tight"></div>
          <div id="slideBody" class="mt-4 text-white/75"></div>
          <ul id="slideBullets" class="mt-4 list-disc pl-5 space-y-2 text-white/75"></ul>
        </div>

        <aside class="rounded-[2rem] border border-white/10 bg-[#0D0D12]/35 p-6">
          <div class="flex items-center justify-between">
            <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>NOTAS</div>
            <div id="slideTime" class="rounded-[2rem] border border-white/10 bg-white/5 px-3 py-2 text-xs text-white/70" style={{ fontFamily: 'JetBrains Mono, monospace' }}></div>
          </div>
          <div id="slideNote" class="mt-3 text-sm text-white/70"></div>

          <div class="mt-6 rounded-[2rem] border border-white/10 bg-white/5 p-4">
            <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>TIMER</div>
            <div class="mt-2 flex items-center justify-between gap-2">
              <div id="timer" class="text-2xl font-extrabold" style={{ fontFamily: 'JetBrains Mono, monospace' }}>00:00</div>
              <button id="timerBtn" class="rounded-[2rem] bg-[color:var(--champagne)] px-4 py-2 font-semibold text-[#0D0D12]">Start</button>
            </div>
            <div class="mt-2 text-xs text-white/55">Tip: apretá <strong>T</strong> para start/stop.</div>
          </div>

          <div class="mt-6">
            <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>PROGRESO</div>
            <div class="mt-2 h-2 rounded-full bg-white/10">
              <div id="bar" class="h-2 rounded-full" style={{ width: '0%', backgroundColor: 'var(--champagne)' }}></div>
            </div>
            <div id="idx" class="mt-2 text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}></div>
          </div>
        </aside>
      </div>

      <div class="mt-5 flex flex-wrap justify-between gap-3">
        <button id="prev" class="rounded-[2rem] border border-white/10 bg-white/5 px-5 py-3 font-semibold">← Anterior</button>
        <button id="next" class="rounded-[2rem] bg-[color:var(--champagne)] px-5 py-3 font-semibold text-[#0D0D12]">Siguiente →</button>
      </div>
    </div>
  </div>

  <script define:vars={{ slides }}>
    const $ = (id) => document.getElementById(id);

    const metaEl = $('slideMeta');
    const titleEl = $('slideTitle');
    const bodyEl = $('slideBody');
    const bulletsEl = $('slideBullets');
    const noteEl = $('slideNote');
    const timeEl = $('slideTime');
    const barEl = $('bar');
    const idxEl = $('idx');

    let i = 0;

    function render() {
      const s = slides[i];
      metaEl.textContent = `${s.k.toUpperCase()} · ${String(i + 1).padStart(2,'0')}/${String(slides.length).padStart(2,'0')}`;
      titleEl.textContent = s.title;
      bodyEl.textContent = s.body || '';
      bulletsEl.innerHTML = '';
      (s.bullets || []).forEach((b) => {
        const li = document.createElement('li');
        li.textContent = b;
        bulletsEl.appendChild(li);
      });
      noteEl.textContent = s.note || '';
      timeEl.textContent = s.time || '';

      const p = (i + 1) / slides.length;
      barEl.style.width = `${Math.round(p * 100)}%`;
      idxEl.textContent = `${Math.round(p * 100)}%`;

      // little entrance
      const box = titleEl.closest('div');
      box.animate(
        [{ opacity: 0.6, transform: 'translateY(6px)' }, { opacity: 1, transform: 'translateY(0px)' }],
        { duration: 220, easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)' }
      );
    }

    function next() { i = Math.min(slides.length - 1, i + 1); render(); }
    function prev() { i = Math.max(0, i - 1); render(); }

    $('next').addEventListener('click', next);
    $('prev').addEventListener('click', prev);

    // keyboard
    window.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ') next();
      if (e.key === 'ArrowLeft') prev();
      if (e.key.toLowerCase() === 't') toggleTimer();
      if (e.key === 'Escape') { i = 0; render(); }
    });

    // timer
    let t = 0;
    let timerId = null;
    const timerEl = $('timer');
    const btn = $('timerBtn');

    function fmt(x) {
      const m = String(Math.floor(x / 60)).padStart(2, '0');
      const s = String(x % 60).padStart(2, '0');
      return `${m}:${s}`;
    }

    function startTimer() {
      if (timerId) return;
      btn.textContent = 'Stop';
      timerId = setInterval(() => {
        t += 1;
        timerEl.textContent = fmt(t);
      }, 1000);
    }

    function stopTimer() {
      if (!timerId) return;
      clearInterval(timerId);
      timerId = null;
      btn.textContent = 'Start';
    }

    function toggleTimer() {
      if (timerId) stopTimer();
      else startTimer();
    }

    btn.addEventListener('click', toggleTimer);

    render();
  </script>
</Layout>
