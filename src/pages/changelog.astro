---
import Layout from '../layouts/Layout.astro';
const today = new Date().toISOString().slice(0, 10);
---

<Layout title="Changelog — Bardo">
  <main class="wrap">
    <h1>Changelog</h1>
    <p class="sub">Cambios semanales.</p>

    <article class="entry">
      <h2>Semana 0 — {today}</h2>
      <ul>
        <li>Definición de idea: “Pedidos por WhatsApp” (rotiserías UY/AR).</li>
        <li>Research de competencia + posicionamiento.</li>
        <li>Landing v0 + CTA.</li>
      </ul>
    </article>

    <div class="cta">
      <a class="secondary" href="/">Volver</a>
    </div>
  </main>

  <style>
    .wrap{max-width:860px;margin:0 auto;padding:56px 18px}
    .sub{opacity:.8;margin-top:6px}
    .entry{margin-top:18px;border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:14px;background:rgba(255,255,255,.06)}
    .entry h2{margin:0 0 8px}
    ul{margin:0;padding-left:18px;opacity:.9}
    .cta{margin-top:18px}
    a.secondary{color:#fff;text-decoration:none;font-weight:800;border:1px solid rgba(255,255,255,.16);padding:11px 14px;border-radius:14px;background:rgba(255,255,255,.08)}
  </style>
</Layout>
