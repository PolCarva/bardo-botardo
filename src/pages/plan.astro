---
import Layout from '../layouts/Layout.astro';
import { lessons } from '../lib/classes';
import { modules } from '../lib/modules';

const lessonByN = new Map(lessons.map((l) => [l.n, l]));
---

<Layout title="Plan — Diseño interactivo">
  <section class="mx-auto max-w-6xl px-5 pt-24">
    <p class="text-xs tracking-[0.22em] text-white/60">PLAN</p>
    <h1 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight">
      16 clases, <span class="italic" style={{ fontFamily: 'Playfair Display, serif', color: 'var(--champagne)' }}>de cero a pro</span>,
      ordenadas por módulos.
    </h1>
    <p class="mt-4 text-white/75">
      Diseño y planificación primero. Frontend + IA después. Backend opcional: Node + Express.
    </p>

    <div class="mt-10 grid gap-4">
      {modules.map((m) => (
        <div class="rounded-[2.5rem] border border-white/10 bg-white/5 p-6">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
                {m.id.toUpperCase()} · {m.lessons.length} clases
              </div>
              <div class="mt-2 text-2xl font-semibold tracking-tight">{m.title}</div>
              <div class="mt-2 text-white/70">{m.subtitle}</div>
            </div>
            <div class="rounded-[2rem] border border-white/10 bg-[#0D0D12]/40 px-4 py-3 text-xs text-white/70" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
              Entrega por módulo: 1 artefacto usable
            </div>
          </div>

          <div class="mt-6 grid gap-3">
            {m.lessons.map((n) => {
              const l = lessonByN.get(n);
              if (!l) return null;
              return (
                <a
                  href={`/clase/${l.slug}`}
                  class="group rounded-[2rem] border border-white/10 bg-[#0D0D12]/35 p-5 transition hover:-translate-y-[1px]"
                >
                  <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                      <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
                        CLASE {String(l.n).padStart(2, '0')}
                      </div>
                      <div class="mt-2 text-lg font-semibold">{l.title}</div>
                      <div class="mt-2 text-sm text-white/70">{l.outcome}</div>
                    </div>
                    <div class="text-xs text-white/55" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
                      {l.tools.join(' · ')}
                    </div>
                  </div>
                  <div class="mt-4 text-sm text-[color:var(--champagne)] font-semibold">
                    Abrir clase →
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
