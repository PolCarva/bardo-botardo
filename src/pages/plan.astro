---
import Layout from '../layouts/Layout.astro';
import { lessons } from '../lib/classes';
---

<Layout title="Plan — Vibecoding 16">
  <section class="mx-auto max-w-6xl px-5 pt-12">
    <p class="text-xs tracking-[0.22em] text-white/60">PLAN</p>
    <h1 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight">
      16 clases, de 0 a pro.
    </h1>
    <p class="mt-4 max-w-2xl text-white/75">
      Cada clase tiene objetivo, herramientas y un entregable. La idea es terminar con una web
      deployada y con IA integrada.
    </p>

    <div class="mt-8 grid gap-4">
      {lessons.map((l) => (
        <a
          href={`/clase/${l.slug}`}
          class="group rounded-[2rem] border border-white/10 bg-white/5 p-5 transition hover:-translate-y-[1px]"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
                CLASE {String(l.n).padStart(2, '0')}
              </div>
              <div class="mt-2 text-lg font-semibold">{l.title}</div>
              <div class="mt-2 text-sm text-white/70">{l.outcome}</div>
            </div>
            <div class="text-xs text-white/60" style={{ fontFamily: 'JetBrains Mono, monospace' }}>
              {l.tools.join(' · ')}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
