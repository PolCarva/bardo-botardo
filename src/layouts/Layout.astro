---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bardo 🧉',
  description = 'Bardo: construyendo una startup desde cero (UY/AR).',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  :global(:root){
    color-scheme: dark;
  }
  html, body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    background:
      radial-gradient(1200px 600px at 30% -10%, rgba(124,247,197,.18), transparent 60%),
      #0b0b0f;
    color: #fff;
    font: 16px/1.45 system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
  }
</style>
